# Load bash completion (cross-platform)
for f in \
    "$(brew --prefix 2>/dev/null)/etc/profile.d/bash_completion.sh" \
    /usr/share/bash-completion/bash_completion \
    /etc/bash_completion
do
    [ -r "$f" ] && source "$f" && break
done

