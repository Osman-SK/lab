
# === Environment setup (early) ===
# MacOS:

if [[ -x /opt/homebrew/bin/brew ]]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
    
    # brew-bash complains, so set:
    export LC_ALL=en_US.UTF-8
    export LC_COLLATE=en_US.UTF-8
    export LANG=en_US.UTF-8
    
    alias ls='ls --color=auto'
    alias ll='ls -lAhF --color=auto'
    
    alias vdir='vdir --color=auto'
    alias dir='dir --color=auto'
    
    #alias ifconfig='ifconfig --color=auto' ; does not support color

    alias grep='grep --color=auto'
    alias fgrep='fgrep --color=auto'
    
    alias lab='cd /Users/osk/Desktop/01_Files/01_Docs/02_Pro/03_KubeCraft/01_Git_Archives/lab'
    alias resume='cd /Users/osk/Desktop/01_Files/01_Docs/02_Pro/09_Job_Resources/01_Resume/01_WorkingOrLatest'

fi

# bash-completion@2 for brew-bash

[[ -r "/opt/homebrew/etc/profile.d/bash_completion.sh" ]] && . "/opt/homebrew/etc/profile.d/bash_completion.sh"


# set cross-paltform default env variables: 
export EDITOR="/usr/bin/vim"
export VISUAL="/usr/bin/vim"   

# enable color support of ls and also add handy aliases
if [ -x /usr/bin/dircolors ]; then
    test -r ~/.dircolors && eval "$(dircolors -b ~/.dircolors)" || eval "$(dircolors -b)"

    alias ls='ls --color=auto'
    alias ll='ls -lAhF --color=auto'

    alias vdir='vdir --color=auto'
    alias dir='dir --color=auto'
    
    alias ip='ip --color=auto'

    alias grep='grep --color=auto'
    alias fgrep='fgrep --color=auto'
    alias egrep='egrep --color=auto'
fi

# PS1 Escape Sequences:
# \u for username, 
# \h for hostname, 
# \w for the pwd, 
# \W for base pwd,
# $ for users, # for root. 

# former white background used:
# PS1='\u@\h \W \$ '

# Colored prompt - light on the eyes (soft cyan + blue)
PS1='${debian_chroot:+($debian_chroot)}\[\033[01;36m\]\u@\h\[\033[00m\]: \[\033[01;34m\]\W \[\033[00m\]\$ '

# History settings 
shopt -s histappend          # append, don't overwrite
HISTCONTROL=ignoreboth       # ignore duplicates and space-prefixed
HISTSIZE=10000
HISTFILESIZE=999000

# Save and reload history after every command (so it's shared across panes/sessions)
# history -a: Append the latest command immediately.
# history -c; history -r: Clear in-memory history and reload from file (keeps everything in sync).
export PROMPT_COMMAND="history -a; history -c; history -r; $PROMPT_COMMAND"

# Shows date and time: 2026-04-01 15:30:00
HISTTIMEFORMAT="%F %T  "



# If not running interactively, don't do anything
case $- in
    *i*) ;;
      *) return;;
esac

# check the window size after each command and, if necessary,
# update the values of LINES and COLUMNS.
shopt -s checkwinsize

# If set, the pattern "**" used in a pathname expansion context will
# match all files and zero or more directories and subdirectories.
#shopt -s globstar

# make less more friendly for non-text input files, see lesspipe(1)
[ -x /usr/bin/lesspipe ] && eval "$(SHELL=/bin/sh lesspipe)"

# Add an "alert" alias for long running commands.  Use like so:
#   sleep 10; alert
alias alert='notify-send --urgency=low -i "$([ $? = 0 ] && echo terminal || echo error)" "$(history|tail -n1|sed -e '\''s/^\s*[0-9]\+\s*//;s/[;&|]\s*alert$//'\'')"'

# enable programmable completion features (you don't need to enable
# this, if it's already enabled in /etc/bash.bashrc and /etc/profile
# sources /etc/bash.bashrc).
if ! shopt -oq posix; then
  if [ -f /usr/share/bash-completion/bash_completion ]; then
    . /usr/share/bash-completion/bash_completion
  elif [ -f /etc/bash_completion ]; then
    . /etc/bash_completion
  fi
fi

export PATH="$HOME/.local/bin:$PATH" # Mischa, per some convention i do not rmbr.

